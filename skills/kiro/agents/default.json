{
  "name": "default",
  "description": "Default agent with pre-authorized commands for skills",
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "gh pr view .*",
        "gh pr diff .*",
        "gh pr list .*",
        "gh pr edit .*",
        "gh pr checkout .*",
        "gh pr checks .*",
        "gh pr merge .*",
        "gh issue view .*",
        "gh issue list .*",
        "gh issue create .*",
        "gh issue comment .*",
        "gh api .*",
        "gh auth status.*",
        "gh auth refresh .*",
        "gh repo view .*",
        "gh repo clone .*",
        "gh run view .*",
        "gh run list .*",
        "gh run download .*",
        "gh run rerun .*",
        "gh run watch .*",
        "gh search .*",
        "timeout .* gh .*",
        "git status.*",
        "git log .*",
        "git diff.*",
        "git branch.*",
        "git checkout .*",
        "git pull.*",
        "git fetch.*",
        "git show .*",
        "git stash.*",
        "git merge .*",
        "git rebase .*",
        "git add .*",
        "git commit .*",
        "git push.*",
        "git remote .*",
        "git rev-parse .*",
        "git cherry-pick .*",
        "go build .*",
        "go test .*",
        "go run .*",
        "go mod .*",
        "go vet .*",
        "go fmt .*",
        "make.*",
        "docker ps.*",
        "docker logs .*",
        "docker compose .*",
        "cat *",
        "grep *",
        "head *",
        "tail *",
        "cut *",
        "tr *",
        "echo *",
        "rm /tmp/.*",
        "mkdir -p .*",
        "cp .*",
        "curl .*",
        "jq .*",
        "sed .kiro",
        "awk .*",
        "sort .*",
        "uniq .*",
        "wc .*",
        "diff .*",
        "tar .*",
        "zip .*",
        "unzip .*"
      ],
      "autoAllowReadonly": true,
      "denyByDefault": false
    }
  }
}
