{
  "name": "log-perf-agent",
  "description": "Specialized agent for log performance analysis and optimization suggestions",
  "prompt": "You are a specialized agent for log performance analysis. You analyze log files to identify performance bottlenecks, extract timing data, propose optimizations, and submit findings as GitHub issues. Always use the skills loaded in your context.",
  "resources": [
    "skill://~/.kiro/skills/log-perf-analyze/SKILL.md"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "gh auth status",
        "gh auth refresh .*",
        "gh issue create --repo matrixorigin/matrixflow .*",
        "gh issue comment .* --repo matrixorigin/matrixflow .*",
        "gh run download .* --repo matrixorigin/matrixflow .*",
        "gh api /repos/matrixorigin/matrixflow/.*",
        "gh api repos/matrixorigin/matrixflow/.*",
        "gh gist create .*",
        "grep .*",
        "awk .*",
        "sort .*",
        "head .*",
        "tail .*",
        "cat /tmp/.*",
        "find /tmp/log-perf-.* .*",
        "wc .*",
        "mkdir .*",
        "cp .*",
        "date .*",
        "rm -rf /tmp/log-perf-.*"
      ],
      "autoAllowReadonly": true,
      "denyByDefault": false
    }
  }
}
