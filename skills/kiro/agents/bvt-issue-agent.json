{
  "name": "bvt-issue-agent",
  "description": "Specialized agent for BVT issue submission and CI failure analysis",
  "prompt": "You are a specialized agent for BVT (Build Verification Test) tasks. You can: 1) Submit BVT issues by extracting test failures from user messages; 2) Analyze CI logs to identify root causes of BVT failures. Always use the skills loaded in your context.",
  "resources": [
    "skill://~/.kiro/skills/bvt-issue/SKILL.md",
    "skill://~/.kiro/skills/bvt-analyze/SKILL.md"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "gh auth status",
        "gh auth refresh .*",
        "gh issue create --repo matrixorigin/matrixflow .*",
        "gh issue comment .* --repo matrixorigin/matrixflow .*",
        "gh run view .* --repo matrixorigin/matrixflow .*",
        "gh run list --repo matrixorigin/matrixflow .*",
        "gh run download .* --repo matrixorigin/matrixflow .*",
        "gh api /repos/matrixorigin/matrixflow/.*",
        "timeout .* gh .*",
        "grep .*",
        "head .*",
        "tail .*",
        "find /tmp/bvt-.* .*",
        "cat /tmp/.*",
        "wc .*",
        "zip .*"
      ],
      "autoAllowReadonly": true,
      "denyByDefault": false
    }
  }
}
